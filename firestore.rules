rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles & Personal Data
    // - Users can only read/write their own profile
    // - Sub-collections (inventory, receipts) are also restricted to the owner
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Recipe History
    // - Users can only read/write their own recipe history
    match /recipe_history/{document} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
